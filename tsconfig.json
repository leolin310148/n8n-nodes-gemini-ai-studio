{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "lib": ["ES2019", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noImplicitAny": true,
    "noUnusedLocals": false
  },
  "include": ["credentials/**/*.ts", "nodes/**/*.ts", "nodes/**/*.json"],
  "exclude": ["dist/**/*", "node_modules/**/*"]
}
